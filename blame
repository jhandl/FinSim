#!/usr/bin/env node

/**
 * Regression Bisect Tool
 * 
 * Automates finding the commit that introduced simulation differences between two branches.
 * 
 * Usage:
 *   node bisect_regression.js --feature <branch> --scenario <path> [--repo <path>]
 */

const fs = require('fs');
const path = require('path');
const { execSync, spawnSync, spawn } = require('child_process');
const os = require('os');
const readline = require('readline');

// --- Helpers ---

function askUser(query) {
  const rl = readline.createInterface({
    input: process.stdin,
    output: process.stdout,
  });

  return new Promise(resolve => rl.question(query, (ans) => {
    rl.close();
    resolve(ans);
  }));
}

// --- Argument Parsing ---

function parseArgs(argv) {
  const args = {
    feature: null,
    base: 'main',
    scenario: null,
    repo: process.cwd(),
    tolerance: 0,
    manual: false,
    port: 8081,
    search: null,
    file: null,
  };

  for (let i = 2; i < argv.length; i++) {
    const arg = argv[i];
    if (arg === '--feature') { args.feature = argv[++i]; continue; }
    if (arg === '--base') { args.base = argv[++i]; continue; }
    if (arg === '--scenario') { args.scenario = argv[++i]; continue; }
    if (arg === '--repo') { args.repo = argv[++i]; continue; }
    if (arg === '--tolerance') { args.tolerance = parseFloat(argv[++i]); continue; }
    if (arg === '--manual') { args.manual = true; continue; }
    if (arg === '--port') { args.port = parseInt(argv[++i], 10); continue; }
    if (arg === '--search') { args.search = argv[++i]; continue; }
    if (arg === '--file') { args.file = argv[++i]; continue; }
    if (arg === '--help' || arg === '-h') {
      printHelp();
      process.exit(0);
    }
  }

  if (!args.feature || (!args.manual && !args.scenario && !args.search)) {
    console.error('Error: --feature and (either --scenario or --manual or --search) are required.');
    printHelp();
    process.exit(1);
  }

  return args;
}

function printHelp() {
  console.log(`
Regression Bisect Tool

Usage:
  ./blame --feature <branch> [--scenario <path> | --manual | --search <regex>] [options]

Options:
  --feature <branch>    Feature branch name to check against base
  --base <branch>       Base branch name (default: main)
  --scenario <path>     Path to the scenario file (CSV/JSON/JS)
  --manual              Interactive mode for visual/manual defects
  --search <regex>      Search for the first/last commit where a file matches this regex
  --file <pattern>      Optional file pattern for --search (e.g., "*.js")
  --port <number>       Port for local server in manual mode (default: 8081)
  --repo <path>         Path to the repository (default: current directory)
  --tolerance <number>  Tolerance for compare.js (default: 0)
`);
}

// --- Git Operations ---

function runGit(cmd, cwd) {
  try {
    return execSync(`git ${cmd}`, { cwd, encoding: 'utf8', stdio: 'pipe' }).trim();
  } catch (e) {
    throw new Error(`Git command failed: git ${cmd}\n${e.stderr}`);
  }
}

function cloneRepo(source, dest) {
  // Use local clone for speed
  execSync(`git clone "${source}" "${dest}"`, { stdio: 'inherit' });

  // Symlink node_modules if it exists
  const nodeModules = path.join(source, 'node_modules');
  if (fs.existsSync(nodeModules)) {
    try {
      fs.symlinkSync(nodeModules, path.join(dest, 'node_modules'));
    } catch (e) {
      console.warn('Warning: Failed to symlink node_modules:', e.message);
    }
  }
}

function checkout(cwd, ref) {
  runGit(`checkout "${ref}"`, cwd);
}

function getCommits(cwd, from, to) {
  const output = runGit(`log "${from}".."${to}" --pretty=format:"%H" --reverse`, cwd);
  return output.split('\n').filter(Boolean);
}

function getCommitInfo(cwd, hash) {
  const msg = runGit(`show -s --format="%s%n%b" "${hash}"`, cwd);
  const stat = runGit(`show --stat "${hash}"`, cwd);
  return { msg, stat };
}

function checkSearch(cwd, regex, fileSpec) {
  try {
    // -l: list files, -E: extended regex
    let fileArg = '';
    if (fileSpec) {
      // Prepend magic to allow matching anywhere in the tree if not already specified
      const pattern = fileSpec.startsWith(':') ? fileSpec : `:(glob)**/${fileSpec}`;
      fileArg = ` -- "${pattern}"`;
    }
    const output = runGit(`grep -lE "${regex}"${fileArg}`, cwd);
    return { hasMatch: true, files: output.split('\n').filter(Boolean) };
  } catch (e) {
    // git grep returns 1 if no matches found
    return { hasMatch: false, files: [] };
  }
}

// --- Comparison Logic ---

function runCompare(repoA, repoB, scenario, tolerance) {
  const comparePath = path.join(process.cwd(), 'compare.js');
  if (!fs.existsSync(comparePath)) {
    throw new Error('Could not locate compare.js in current directory.');
  }

  const args = [
    comparePath,
    '--repoA', repoA,
    '--repoB', repoB,
    '--output', 'json',
    '--tolerance', String(tolerance),
    '--forceDeterministic',
    scenario
  ];

  const result = spawnSync(process.execPath, args, { encoding: 'utf8' });

  if (result.error) {
    throw result.error;
  }

  try {
    const output = JSON.parse(result.stdout);
    const report = Array.isArray(output) ? output[0] : (output.reports ? output.reports[0] : output);
    if (!report) {
      if (result.status > 1) {
        throw new Error(`compare.js failed with status ${result.status}: ${result.stderr}`);
      }
      return { hasDiff: false, diffs: [] };
    }

    return {
      hasDiff: report.diffs && report.diffs.length > 0,
      diffs: report.diffs || []
    };
  } catch (e) {
    console.error('Failed to parse compare.js output:', result.stdout);
    console.error('Stderr:', result.stderr);
    throw new Error('compare.js output parsing failed');
  }
}

// --- Main ---

async function main() {
  const args = parseArgs(process.argv);

  const originalRepo = path.resolve(args.repo);
  const scenarioPath = args.scenario ? path.resolve(args.scenario) : null;

  if (!fs.existsSync(originalRepo)) {
    throw new Error(`Repository not found at ${originalRepo}`);
  }
  if (scenarioPath && !fs.existsSync(scenarioPath)) {
    throw new Error(`Scenario not found at ${scenarioPath}`);
  }

  const tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'blame-'));
  const dirMain = path.join(tmpDir, 'main');
  const dirFeature = path.join(tmpDir, 'feature');
  let serverProcess = null;

  try {
    // Clone repo
    cloneRepo(originalRepo, dirMain);
    cloneRepo(originalRepo, dirFeature);

    // Checkout initial state
    checkout(dirMain, args.base);

    // We need both base and feature in dirFeature to compute the log
    checkout(dirFeature, args.base);
    checkout(dirFeature, args.feature);

    // Get commits
    const commits = getCommits(dirFeature, args.base, args.feature);
    console.log(`Found ${commits.length} commits to check.`);

    if (commits.length === 0) {
      console.log('No commits found between main and feature branch.');
      return;
    }

    if (args.manual) {
      console.log(`Starting server on port ${args.port} for ${dirFeature}...`);
      serverProcess = spawn('python3', ['-m', 'http.server', String(args.port)], {
        cwd: dirFeature,
        stdio: 'ignore'
      });
      console.log(`Simulator available at: http://localhost:${args.port}\n`);
    }

    console.log(`Feature repo: ${dirFeature}`);
    console.log(`Base repo:    ${dirMain} (for reference)\n`);

    let searchMode = 'first';
    if (args.search) {
      let answer = '';
      while (answer !== 'f' && answer !== 'l') {
        answer = (await askUser('Search for the (f)irst or (l)ast occurrence? (f/l): ')).toLowerCase();
      }
      searchMode = (answer === 'f' ? 'first' : 'last');
    }

    // Initial check: Base vs Feature (Head)
    let hasInitialDiff = false;
    if (args.manual) {
      console.log(`Manual mode: Checking if defect exists in ${args.feature}...`);
      checkout(dirFeature, args.feature);
      
      let answer = '';
      while (answer !== 'y' && answer !== 'n') {
        answer = (await askUser('Do you see the defect in the feature branch? (y/n): ')).toLowerCase();
      }
      hasInitialDiff = (answer === 'y');
    } else if (args.search) {
      hasInitialDiff = true; // For search, we enter the loop and find out
    } else {
      const initialResult = runCompare(dirMain, dirFeature, scenarioPath, args.tolerance);
      hasInitialDiff = initialResult.hasDiff;
    }

    if (!hasInitialDiff) {
      console.log('No differences/defects found between base and feature branch.');
      return;
    }

    let low = 0;
    let high = commits.length - 1;
    let offendingIndex = -1;
    let matchedFiles = [];

    while (low <= high) {
      const mid = Math.floor((low + high) / 2);
      const commitHash = commits[mid];

      if (args.manual) {
        console.log(`\n--- Checking commit ${mid + 1}/${commits.length}: ${commitHash.substring(0, 7)} ---`);
        checkout(dirFeature, commitHash);
        const info = getCommitInfo(dirFeature, commitHash);
        console.log(`Message: ${info.msg.split('\n')[0]}`);
        
        let answer = '';
        while (answer !== 'y' && answer !== 'n') {
          answer = (await askUser('Do you see the defect? (y/n): ')).toLowerCase();
        }
        
        if (answer === 'y') {
          offendingIndex = mid;
          high = mid - 1;
        } else {
          low = mid + 1;
        }
      } else if (args.search) {
        process.stdout.write(`Checking commit ${mid + 1}/${commits.length}: ${commitHash.substring(0, 7)}... `);

        checkout(dirFeature, commitHash);
        const result = checkSearch(dirFeature, args.search, args.file);

        if (result.hasMatch) {
          offendingIndex = mid;
          matchedFiles = result.files;
          console.log(`Match found in ${result.files.length} file(s).`);
          if (searchMode === 'first') {
            high = mid - 1;
          } else {
            low = mid + 1;
          }
        } else {
          console.log('No match.');
          if (searchMode === 'first') {
            low = mid + 1;
          } else {
            high = mid - 1;
          }
        }
      } else {
        process.stdout.write(`Checking commit ${mid + 1}/${commits.length}: ${commitHash.substring(0, 7)}... `);

        checkout(dirFeature, commitHash);

        const result = runCompare(dirMain, dirFeature, scenarioPath, args.tolerance);

        if (result.hasDiff) {
          offendingIndex = mid;
          high = mid - 1;
          console.log('Diff found.');
        } else {
          low = mid + 1;
          console.log('No diff.');
        }
      }
    }

    if (offendingIndex !== -1) {
      const badCommit = commits[offendingIndex];

      const info = getCommitInfo(dirFeature, badCommit);
      console.log(`\nFound ${args.search ? 'matching' : 'offending'} commit: ${badCommit.substring(0, 7)}`);
      console.log(`Message: ${info.msg.split('\n')[0]}`);

      if (args.search) {
        console.log(`\nMatching files:\n${matchedFiles.join('\n')}\n`);
      } else {
        console.log(`\nChanges:\n${info.stat}\n`);

        if (!args.manual) {
          console.log('Value Differences:\n');
          checkout(dirFeature, badCommit);
          const finalResult = runCompare(dirMain, dirFeature, scenarioPath, args.tolerance);

          if (finalResult.diffs.length > 0) {
            const diffs = finalResult.diffs;
            diffs.sort((a, b) => a.row - b.row);

            // Concise output format: Age <age>: <field> Main=<val> Feature=<val>
            diffs.forEach(d => {
              if (d.type === 'row_mismatch') {
                console.log(`Row ${d.row}: Row mismatch (Main=${d.aExists}, Feature=${d.bExists})`);
              } else {
                const ageStr = (d.age !== null && d.age !== undefined) ? `Age ${d.age}` : `Row ${d.row}`;
                console.log(`${ageStr}, "${d.field}", Main=${d.a}, Feature=${d.b}`);
              }
            });
          } else {
            console.log('No differences found in final check? This shouldn\'t happen.');
          }
        }
      }

    } else {
      console.log(`Search completed but no single ${args.search ? 'matching' : 'offending'} commit found.`);
    }

  } catch (err) {
    console.error('An error occurred:', err);
  } finally {
    if (serverProcess) {
      serverProcess.kill();
    }
    fs.rmSync(tmpDir, { recursive: true, force: true });
  }
}

main();
