{
  "version": 1,
  "hooks": {
    "beforeReadFile": [
      {
        "command": "python3 .cursor/hooks/pre-write-template.py",
        "failClosed": true
      }
    ],
    "beforeShellExecution": [
      {
        "command": "python3 .cursor/hooks/pre-write-template.py",
        "matcher": ".cursor/hooks/pre-write-template.py",
        "failClosed": true
      }
    ],
    "preToolUse": [
      {
        "command": "python3 .cursor/hooks/pre-write-template.py",
        "matcher": "Read",
        "failClosed": true
      },
      {
        "command": "python3 .cursor/hooks/pre-write-template.py",
        "matcher": "Write",
        "failClosed": true
      }
    ]
  }
}
